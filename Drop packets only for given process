#include <linux/bpf.h>
#include <bpf/bpf_helpers.h>
#include <linux/in.h>

#define ALLOWED_PORT 4040

SEC("cgroup/connect4")
int restrict_process_port(struct bpf_sock_addr *ctx)
{
    char comm[16];

    bpf_get_current_comm(&comm, sizeof(comm));

    // Check if process name is "myprocess"
    if (__builtin_memcmp(comm, "myprocess", 9) == 0) {

        if (ctx->user_port != bpf_htons(ALLOWED_PORT)) {
            return 0;  // Drop connection
        }
    }

    return 1;  // Allow
}

